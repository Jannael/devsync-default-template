---
interface Props {
  name: string;
  url: string;
  icon: string;
}

const { name, url, icon } = Astro.props;
---

<li class="group">
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 rounded-lg border border-border bg-main px-4 py-2 text-sm font-medium transition-all duration-300 hover:border-accent hover:text-accent"
  >
    <img src={icon} alt={name} class="h-4 w-4" width="16" height="16" />
    {name && <span>{name}</span>}
  </a>
</li>
