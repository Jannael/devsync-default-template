---
interface Props {
  name: string
  url: string
  icon: string
  bg?: string
  text?: string
}

const { name, url, icon, bg, text } = Astro.props
---

<li class="group">
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="relative flex items-center gap-3 rounded-full border border-text/15 bg-main/50 px-5 py-3 shadow-lg shadow-main/10 backdrop-blur-sm transition-all duration-300 hover:scale-105 hover:border-third hover:bg-main/80 hover:shadow-xl hover:shadow-third/20"
  >
    <img src={icon} alt={name} class="h-6 w-6" width="24" height="24" />
    {name && <span class={`text-sm font-medium ${text} pr-1 text-text`}>{name}</span>}
    <div class="absolute inset-0 rounded-full bg-linear-to-r from-third/20 to-accent/20 opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
  </a>
</li>