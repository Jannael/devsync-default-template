---
interface Props {
  name?: string;
  img?: string;
  web?: string;
  links?: {
    name?: string;
    url?: string;
    mdBadge?: string;
    icon?: string;
  }[];
  description?: string;
  list?: {
    title?: string;
    items?: {
      highlight?: string;
      description?: string;
    }[];
  };
  skills?: {
    name?: string;
    mdBadge?: string;
    icon?: string;
  }[];
}

const { name, img, web, links, description, list, skills } = Astro.props;
---

<li class="group">
  <article class="card overflow-hidden transition-all duration-300">
    {img && (
      <a
        href={web ?? "#"}
        target="_blank"
        rel="noopener noreferrer"
        class="block overflow-hidden"
      >
        <img
          src={img}
          alt={name ?? "Project preview"}
          class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-105"
          width="800"
          height="450"
        />
      </a>
    )}

    <div class="p-6">
      {name && (
        <h3 class="mb-3 text-xl font-bold">
          {name}
        </h3>
      )}

      {description && (
        <p class="mb-4 text-sm leading-relaxed text-text-secondary">
          {description}
        </p>
      )}

      {links?.length && (
        <div class="mb-4 flex flex-wrap gap-2">
          {links.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center rounded-lg border border-border bg-main px-3 py-1.5 text-xs font-medium transition-all duration-300 hover:border-accent hover:text-accent"
            >
              {link.icon && <img src={link.icon} alt={link.name} class="mr-1.5 inline h-3.5 w-3.5" />}
              {link.name}
            </a>
          ))}
        </div>
      )}

      {skills?.length && (
        <div class="flex flex-wrap gap-2">
          {skills.map((skill) => (
            <span class="inline-flex items-center rounded-full border border-border bg-main px-2.5 py-1 text-xs font-medium">
              {skill.icon && <img src={skill.icon} alt={skill.name} class="mr-1.5 inline h-3 w-3" />}
              {skill.name}
            </span>
          ))}
        </div>
      )}
    </div>
  </article>
</li>
