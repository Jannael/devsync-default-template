---
interface Props {
  name?: string
  img?: string
  web?: string
  links?: {
    name?: string
    url?: string
    mdBadge?: string
    icon?: string
  }[]
  description?: string
  list?: {
    title?: string
    items?: {
      highlight?: string
      description?: string
    }[]
  }
  skills?: {
    name?: string
    mdBadge?: string
    icon?: string
  }[]
}

const { name, img, web, links, description, list, skills } = Astro.props
---

<li class="relative mb-10 w-full lg:mb-0">
  <article class="border-text/30 overflow-hidden rounded-2xl border">
    {
      img && (
        <a href={web ?? '#'} target="_blank" rel="noopener noreferrer" class="group block">
          <img
            src={img}
            alt={name ?? 'Project preview'}
            class="h-52 w-full object-cover transition-transform duration-300 group-hover:scale-[1.02] lg:h-64"
            width="1200"
            height="675"
          />
        </a>
      )
    }

    <div class="p-6 lg:p-8">
      {name && <h3 class="mb-3 text-xl font-semibold lg:text-2xl">{name}</h3>}

      {description && <p class="text-text/70 mb-6 text-base leading-6">{description}</p>}

      {
        list?.items?.length ? (
          <>
            <header class="mb-2 text-sm font-bold uppercase tracking-wide">{list.title}</header>
            <ul class="text-text/90 mb-6 list-disc space-y-2 pl-6 text-sm">
              {list.items.map((item) => (
                <li class="text-text/70">
                  <span class="text-text font-semibold">{item.highlight}:</span> {item.description}
                </li>
              ))}
            </ul>
          </>
        ) : null
      }

      <div class="mb-6 flex flex-wrap gap-2">
        {
          links?.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-main/60 border-text/50 text-text/80 hover:bg-main flex items-center justify-center rounded-full border px-3 py-1 text-sm transition-colors hover:scale-105"
            >
              {link.icon && <img src={link.icon} alt={link.name} class="mr-2 inline h-4 w-4" />}
              {link.name}
            </a>
          ))
        }
      </div>

      {
        skills?.length ? (
          <div class="mb-6 flex flex-wrap gap-2">
            {skills.map((skill) => (
              <span class="bg-third/70 hover:bg-third text-text/80 border-text/50 rounded-full border px-3 py-1 text-sm transition-transform hover:scale-105">
                <img src={skill.icon} alt={skill.name} class="mr-2 inline h-4 w-4" />
                {skill.name}
              </span>
            ))}
          </div>
        ) : null
      }
    </div>
  </article>
</li>
