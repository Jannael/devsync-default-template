---
import devsync, { getLangData } from '@core'
import '@/styles/global.css'
import '@fontsource-variable/roboto/wght.css'
import robotoLatinWoff2 from '@fontsource-variable/roboto/files/roboto-latin-wght-normal.woff2?url'
import { defaultLang, languages } from '@core'
import { translations, type availableLangsType } from '@/devsync/fields-translations'

export function getStaticPaths() {
  return languages.map((lang) => ({
    params: { lang },
  }))
}
const lang = (Astro.params.lang || defaultLang) as availableLangsType

const profile = getLangData(devsync, lang)
const experience = profile.experience ?? []
const projects = profile.projects ?? []
const education = profile.education ?? []
const certifications = profile.certifications ?? []
const socialMedia = devsync.socialMedia ?? []
const userLanguages = profile.languages ?? []

const skillsFromSkillBlocks = [
  ...experience.flatMap((item) => (item.skills ?? []).map((skill) => skill.name)),
  ...projects.flatMap((item) => (item.skills ?? []).map((skill) => skill.name)),
  ...certifications.flatMap((item) => (item.skills ?? []).map((skill) => skill.name)),
]

const coreSkills = [...new Set(skillsFromSkillBlocks)].filter(Boolean)
---

<html lang={lang} class="bg-white">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{devsync.name ?? 'Candidate'} | CV</title>
    <link rel="preload" href={robotoLatinWoff2} as="font" type="font/woff2" crossorigin />
    <meta
      name="description"
      content={`ATS-ready CV generated from DEVSYNC.json for ${devsync.name ?? 'candidate profile'}`}
    />
    <style>
      body {
        font-family: 'Roboto Variable', sans-serif;
        background-color: #ffffff !important;
        background-image: none !important;
      }
    </style>
  </head>
  <body class="bg-white text-slate-900 antialiased">
    <main class="mx-auto max-w-4xl px-6 py-5 print:max-w-none print:px-0 print:py-0">
      <header class="border-b border-slate-300 pb-5">
        <h1 class="text-3xl font-bold tracking-tight">
          {(devsync.name ?? 'Candidate Name') + (profile.jobTitle ? ' | ' + profile.jobTitle : '')}
        </h1>
        {profile.description && <p class="mt-3 text-sm leading-6">{profile.description}</p>}
        {
          (devsync.address || devsync.email || devsync.phone) && (
            <p class="mt-2 text-sm leading-6">
              {[devsync.address, devsync.email, devsync.phone].filter(Boolean).join(' | ')}
            </p>
          )
        }
        {
          socialMedia.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm leading-6">
              {socialMedia.map((item) => (
                <p>
                  <span class="font-semibold">{item.name}:</span>{' '}
                  <a class="underline decoration-slate-400 underline-offset-2" href={item.url}>
                    {item.url}
                  </a>
                </p>
              ))}
            </div>
          )
        }
      </header>

      {
        coreSkills.length > 0 && (
          <section class="mt-5">
            <h2 class="text-base font-semibold tracking-wider uppercase">
              {translations[lang]['Core Skills']}
            </h2>
            <p class="mt-2 text-sm leading-6">{coreSkills.join(' | ')}</p>
          </section>
        )
      }

      {
        experience.length > 0 && (
          <section class="mt-7">
            <h2 class="text-base font-semibold tracking-wider uppercase">
              {translations[lang]['Professional Experience']}
            </h2>
            <div class="mt-3 space-y-6">
              {experience.map((item) => (
                <article>
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <h3 class="text-base font-semibold">
                      {item.position ?? 'Position'} | {item.company ?? 'Company'}
                    </h3>
                    <p class="text-sm">{item.date ?? ''}</p>
                  </div>
                  {item.description && <p class="mt-2 text-sm leading-6">{item.description}</p>}
                  {item.list?.items && item.list.items.length > 0 && (
                    <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-6">
                      {item.list.items.map((entry) => (
                        <li>
                          <span class="font-semibold">{entry.highlight}:</span> {entry.description}
                        </li>
                      ))}
                    </ul>
                  )}
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        projects.length > 0 && (
          <section class="mt-7">
            <h2 class="text-base font-semibold tracking-wider uppercase">
              {translations[lang]['Projects']}
            </h2>
            <div class="mt-3 space-y-6">
              {projects.map((item) => (
                <article>
                  <h3 class="text-base font-semibold">{item.name ?? 'Project'}</h3>
                  {item.description && <p class="mt-2 text-sm leading-6">{item.description}</p>}
                  {item.list?.items && item.list.items.length > 0 && (
                    <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-6">
                      {item.list.items.map((entry) => (
                        <li>
                          <span class="font-semibold">{entry.highlight}:</span> {entry.description}
                        </li>
                      ))}
                    </ul>
                  )}
                  {item.links && item.links.length > 0 && (
                    <div class="mt-2 space-y-1 text-sm leading-6">
                      {item.links.map((link) => (
                        <p>
                          <span class="font-semibold">{link.name}:</span>{' '}
                          <a
                            class="underline decoration-slate-400 underline-offset-2"
                            href={link.url}
                          >
                            {link.url}
                          </a>
                        </p>
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        education.length > 0 && (
          <section class="mt-7">
            <h2 class="text-base font-semibold tracking-wider uppercase">
              {translations[lang]['Education']}
            </h2>
            <div class="mt-3 space-y-5">
              {education.map((item) => (
                <article>
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <h3 class="text-base font-semibold">
                      {item.degree ?? 'Degree'} | {item.name ?? 'Institution'}
                    </h3>
                    <p class="text-sm">{item.date ?? ''}</p>
                  </div>
                  {item.list?.items && item.list.items.length > 0 && (
                    <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-6">
                      {item.list.items.map((entry) => (
                        <li>
                          <span class="font-semibold">{entry.highlight}:</span> {entry.description}
                        </li>
                      ))}
                    </ul>
                  )}
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        certifications.length > 0 && (
          <section class="mt-7">
            <h2 class="text-base font-semibold tracking-wider uppercase">
              {translations[lang]['Certifications']}
            </h2>
            <div class="mt-3 space-y-5">
              {certifications.map((item) => (
                <article>
                  <h3 class="text-base font-semibold">{item.name ?? 'Certification'}</h3>
                  {item.url && (
                    <p class="mt-1 text-sm leading-6">
                      <span class="font-semibold">{translations[lang]['credential']}</span>{' '}
                      <a class="underline decoration-slate-400 underline-offset-2" href={item.url}>
                        {item.url}
                      </a>
                    </p>
                  )}
                  {item.list?.items && item.list.items.length > 0 && (
                    <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-6">
                      {item.list.items.map((entry) => (
                        <li>
                          <span class="font-semibold">{entry.highlight}:</span> {entry.description}
                        </li>
                      ))}
                    </ul>
                  )}
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        userLanguages.length > 0 && (
          <section class="mt-7 flex items-center">
            <h2 class="text-base font-semibold tracking-wider uppercase">
              {translations[lang]['Languages']}
            </h2>
            <p class="pl-2 text-sm leading-6">
              {userLanguages.map((item) => item.name).join(' | ')}
            </p>
          </section>
        )
      }
    </main>
  </body>
</html>
