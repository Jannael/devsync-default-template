---
import Badge from "@/components/badge.astro";
import devsync from "@core";
import { defaultLang } from "@core";

const lang = (Astro.params.lang || defaultLang).toLowerCase();
const profile = devsync[lang] ?? devsync[defaultLang];
const firstName = devsync.name?.split(" ")[0];
---

<section class="relative m-auto w-full max-w-4xl px-6 py-16 lg:py-24">
  <div
    class="flex flex-col items-start gap-10 lg:flex-row lg:items-center lg:gap-16"
  >
    <div class="relative shrink-0">
      {
        devsync.img && devsync.img.length > 1 && (
          <div class="relative">
            <img
              src={devsync.img}
              alt={devsync.name}
              class="relative z-10 h-32 w-32 rounded-full border-2 border-accent object-cover lg:h-40 lg:w-40"
              width="160"
              height="160"
              loading="eager"
            />
            <div class="absolute -right-4 -top-4 z-20 rotate-12 rounded bg-accent-light px-3 py-1 text-xs font-bold text-accent shadow-sm">
              {firstName}
            </div>
          </div>
        )
      }
    </div>

    <div class="flex-1">
      <h1 class="mb-3 text-4xl font-extrabold tracking-tight lg:text-6xl">
        {devsync.name}
      </h1>
      <h2 class="mb-4 text-xl font-medium lg:text-2xl">
        <span class="highlight">{profile.jobTitle}</span>
      </h2>
      <p
        class="mb-8 max-w-lg text-base leading-relaxed text-text-secondary lg:text-lg"
      >
        {profile.description}
      </p>

      {
        devsync.socialMedia && devsync.socialMedia.length > 0 && (
          <ul class="flex flex-wrap items-center gap-3">
            {devsync.socialMedia.map((social) => (
              <Badge name={social.name} url={social.url} icon={social.icon} />
            ))}
            <Badge
              name="CV"
              url={"/CV-" + lang + ".pdf"}
              icon="/icons/cv.svg"
            />
          </ul>
        )
      }
    </div>
  </div>
</section>
