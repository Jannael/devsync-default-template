---
import devsync from '@/devsync/devsync'
import { defaultLang } from '@/devsync/devsync'
import { translations, type availableLangsType } from '@/devsync/fields-translations'
import InfoCard from '@/components/info-card.astro'

const lang = (Astro.params.lang || defaultLang).toLowerCase() as availableLangsType
const profile = devsync[lang] ?? devsync[defaultLang]
const experience = profile.experience ?? []
const translation = translations[lang]
---

{
  experience.length > 0 && (
    <section class="relative m-auto flex h-fit w-full max-w-6xl flex-col items-center px-6 lg:pb-24">
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-3xl font-bold tracking-tight lg:text-5xl">{translation['Professional Experience']}</h2>
        <div class="section-divider mx-auto w-24" />
      </div>
      <ul class="relative flex w-full flex-wrap justify-center gap-8 lg:gap-10">
        {experience.map(({ company, position, img, date, links, description, list, skills }) => (
          <InfoCard
            {company}
            {position}
            {img}
            {date}
            {links}
            {description}
            {list}
            {skills}
            expand={experience.length === 1}
          />
        ))}
      </ul>
    </section>
  )
}