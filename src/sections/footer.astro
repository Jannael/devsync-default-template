---
import devsync from '@core'

const fullName = devsync.name ?? 'Portfolio'
const year = new Date().getFullYear()
const socialMedia = devsync.socialMedia ?? []
---

<footer class="border-border mt-16 border-t">
  <div
    class="m-auto flex w-full max-w-4xl flex-col items-center justify-between gap-4 px-6 py-8 md:flex-row"
  >
    <div class="flex items-center gap-3">
      <span class="text-text-secondary text-sm">{year} {fullName}</span>
      <span class="text-text-secondary">·</span>
      <span class="text-text-secondary text-sm">Built with Devsync</span>
    </div>

    {
      socialMedia.length > 0 && (
        <div class="flex flex-wrap items-center gap-5">
          {socialMedia.slice(0, 3).map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary hover:text-accent text-sm underline underline-offset-4 transition-colors"
            >
              {social.name}
            </a>
          ))}
        </div>
      )
    }
  </div>
</footer>
