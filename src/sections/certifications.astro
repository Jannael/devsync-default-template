---
import {
  translations,
  type availableLangsType,
} from "@/devsync/fields-translations";
import devsync, { defaultLang } from "@/devsync/devsync";

const lang = (
  Astro.params.lang || defaultLang
).toLowerCase() as availableLangsType;
const profile = devsync[lang] ?? devsync[defaultLang];
const certifications = profile.certifications ?? [];
const translation = translations[lang];
---

{
  certifications.length > 0 && (
    <section class="relative m-auto w-full max-w-4xl px-6 py-16">
      <div class="mb-12">
        <h2 class="mb-2 inline-block rounded bg-accent-light px-3 py-1 text-2xl font-bold lg:text-3xl">
          {translation["Certifications"]}
        </h2>
      </div>

      <ul class="space-y-6">
        {certifications.map(({ name, url, list, skills }) => (
          <li class="card group relative overflow-hidden p-6 transition-all duration-300">
            <div class="absolute left-0 top-0 h-full w-1 bg-accent"></div>

            <div class="mb-4 flex flex-wrap items-center gap-4">
              <div class="flex-1">
                <h3 class="text-lg font-bold lg:text-xl">{name}</h3>
              </div>
              {url && (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center rounded-lg border border-border bg-main px-4 py-2 text-sm font-medium transition-all duration-300 hover:border-accent hover:text-accent"
                >
                  {translation["View Certificate"]}
                </a>
              )}
            </div>

            {list?.items?.length && (
              <ul class="mb-4 space-y-1.5 pl-4">
                {list.items.map((item) => (
                  <li class="text-sm text-text-secondary">
                    <span class="font-medium text-text">{item.highlight}:</span> {item.description}
                  </li>
                ))}
              </ul>
            )}

            {skills?.length && (
              <div class="flex flex-wrap gap-2">
                {skills.map((skill) => (
                  <span class="inline-flex items-center rounded-full border border-border bg-main px-2.5 py-1 text-xs font-medium">
                    {skill.icon && <img src={skill.icon} alt={skill.name} class="mr-1.5 inline h-3 w-3" />}
                    {skill.name}
                  </span>
                ))}
              </div>
            )}
          </li>
        ))}
      </ul>
    </section>
  )
}
