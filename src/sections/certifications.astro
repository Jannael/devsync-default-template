---
import { translations, type availableLangsType } from '@/devsync/fields-translations'
import devsync, { defaultLang } from '@/devsync/devsync'

const lang = (Astro.params.lang || defaultLang).toLowerCase() as availableLangsType
const profile = devsync[lang] ?? devsync[defaultLang]
const certifications = profile.certifications ?? []
const translation = translations[lang]
---

{
  certifications.length > 0 && (
    <section class="relative m-auto flex h-fit w-full max-w-5xl flex-col items-center justify-center pb-20">
      <h2 class="mb-16 text-xl lg:text-5xl">{translation['Certifications']}</h2>
      <ul class="relative flex w-full flex-col items-center justify-center gap-20 px-10 lg:px-0">
        {certifications.map(({ name, url, list, skills }) => (
          <li class="border-accent/40 border-l-3 rounded-xl px-10 py-4">
            <article>
              <div class="mb-3 flex flex-wrap items-center gap-3">
                <h3 class="text-base font-semibold lg:text-lg">{name}</h3>
                {url && (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bg-main/60 border-text/30 text-text/80 rounded-full border px-3 py-1 text-xs"
                  >
                    {translation['View Certificate']}
                  </a>
                )}
              </div>

              {list?.items?.length ? (
                <ul class="text-text/80 mb-3 list-disc space-y-1 pl-5 text-sm">
                  {list.items.map((item) => (
                    <li>
                      <span class="text-text font-medium">{item.highlight}:</span>{' '}
                      {item.description}
                    </li>
                  ))}
                </ul>
              ) : null}

              {skills?.length ? (
                <div class="flex flex-wrap gap-2">
                  {skills.map((skill) => (
                    <span class="bg-third/60 text-text/80 border-text/30 rounded-full border px-3 py-1 text-xs">
                      {skill.icon && (
                        <img src={skill.icon} alt={skill.name} class="mr-2 inline h-4 w-4" />
                      )}
                      {skill.name}
                    </span>
                  ))}
                </div>
              ) : null}
            </article>
          </li>
        ))}
      </ul>
    </section>
  )
}
