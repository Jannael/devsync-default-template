---
import { translations, type availableLangsType } from '@/devsync/fields-translations'
import devsync, { getLangData, defaultLang } from '@core'

const lang = (Astro.params.lang || defaultLang).toLowerCase() as availableLangsType
const profile = getLangData(devsync, lang)
const certifications = profile.certifications ?? []
const translation = translations[lang]
---

{
  certifications.length > 0 && (
    <section class="relative m-auto w-full max-w-4xl px-6 py-16">
      <div class="mb-12">
        <h2 class="bg-accent-light mb-2 inline-block rounded px-3 py-1 text-2xl font-bold lg:text-3xl">
          {translation['Certifications']}
        </h2>
      </div>

      <ul class="space-y-6">
        {certifications.map(({ name, url, list, skills }) => (
          <li class="card group relative overflow-hidden p-6 transition-all duration-300">
            <div class="bg-accent absolute top-0 left-0 h-full w-1" />

            <div class="mb-4 flex flex-wrap items-center gap-4">
              <div class="flex-1">
                <h3 class="text-lg font-bold lg:text-xl">{name}</h3>
              </div>
              {url && (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="border-border bg-main hover:border-accent hover:text-accent inline-flex items-center rounded-lg border px-4 py-2 text-sm font-medium transition-all duration-300"
                >
                  {translation['View Certificate']}
                </a>
              )}
            </div>

            {list?.items?.length && (
              <ul class="mb-4 space-y-1.5 pl-4">
                {list.items.map((item) => (
                  <li class="text-text-secondary text-sm">
                    <span class="text-text font-medium">{item.highlight}:</span>{' '}{item.description}
                  </li>
                ))}
              </ul>
            )}

            {skills?.length && (
              <div class="flex flex-wrap gap-2">
                {skills.map((skill) => (
                  <span class="border-border bg-main inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium">
                    {skill.icon && (
                      <img src={skill.icon} alt={skill.name} class="mr-1.5 inline h-3 w-3" />
                    )}
                    {skill.name}
                  </span>
                ))}
              </div>
            )}
          </li>
        ))}
      </ul>
    </section>
  )
}
