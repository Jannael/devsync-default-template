---
import { translations, type availableLangsType } from '@/const/fields-translations'
import devsync, { defaultLang } from '@/devsync'

const lang = (Astro.params.lang || defaultLang).toLowerCase() as availableLangsType
const profile = devsync[lang] ?? devsync[defaultLang]
const education = profile.education ?? []
const translation = translations[lang]
---

{
  education.length > 0 && (
    <section class="relative m-auto flex h-fit w-full max-w-5xl flex-col items-center justify-center lg:pb-20">
      <h2 class="mb-16 text-xl lg:text-5xl">{translation['Education']}</h2>
      <ul class="relative flex w-full flex-col items-center justify-center gap-10 px-10 lg:px-0">
        {education.map(({ name, degree, img, date, links, list }) => (
          <li class="border-accent/30 relative mb-10 border-y px-10 py-8 last:mb-0">
            <article>
              <div class="mb-3 flex flex-wrap items-center gap-3">
                {img && (
                  <img
                    src={img}
                    alt={name}
                    width="30"
                    height="30"
                    class="h-8 w-8 rounded-full object-cover"
                  />
                )}
                <h3 class="text-base font-semibold lg:text-lg">{degree}</h3>
                {name && <span class="text-text/70 text-sm">at {name}</span>}
                {date && (
                  <span class="text-text/70 border-text/30 rounded-full border px-2 py-0.5 text-xs">
                    {date}
                  </span>
                )}
              </div>

              {list?.items?.length ? (
                <ul class="text-text/80 mb-3 list-disc space-y-1 pl-5 text-sm">
                  {list.items.map((item) => (
                    <li>
                      <span class="text-text font-medium">{item.highlight}:</span>{' '}
                      {item.description}
                    </li>
                  ))}
                </ul>
              ) : null}

              {links?.length ? (
                <div class="flex flex-wrap gap-2">
                  {links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-accent text-xs underline decoration-transparent transition-colors hover:decoration-current"
                    >
                      {link.name}
                    </a>
                  ))}
                </div>
              ) : null}
            </article>
          </li>
        ))}
      </ul>
    </section>
  )
}
