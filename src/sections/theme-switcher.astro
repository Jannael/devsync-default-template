---
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<button
  id="theme-switcher"
  type="button"
  class={`${className} bg-third/70 hover:bg-third/80 flex h-11 w-11 items-center justify-center rounded-full transition-transform hover:scale-105`}
  aria-label="Toggle theme"
  aria-pressed="false"
>
  <img
    src="/icons/moon.svg"
    alt=""
    width="22"
    height="22"
    class="theme-icon-moon"
    aria-hidden="true"
  />
  <img
    src="/icons/sun.svg"
    alt=""
    width="22"
    height="22"
    class="theme-icon-sun hidden"
    aria-hidden="true"
  />
</button>

<script is:inline>
  const button = document.querySelector('#theme-switcher')
  if (!button) {
    throw new Error('Theme switcher button not found')
  }

  const moonIcon = button.querySelector('.theme-icon-moon')
  const sunIcon = button.querySelector('.theme-icon-sun')

  if (!moonIcon || !sunIcon) {
    throw new Error('Theme switcher icons not found')
  }

  const syncButtonTheme = () => {
    const isDark = document.documentElement.classList.contains('dark')
    button.setAttribute('aria-pressed', String(isDark))
    button.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode')
    moonIcon.classList.toggle('hidden', isDark)
    sunIcon.classList.toggle('hidden', !isDark)
  }

  syncButtonTheme()

  button.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark')
    localStorage.setItem('theme', isDark ? 'dark' : 'light')
    syncButtonTheme()
  })
</script>
