---
interface Props {
  class?: string
}
---

<button
  id="theme-switcher"
  type="button"
  class="group border-border bg-main hover:border-accent hover:text-accent flex h-9 w-9 items-center justify-center rounded-lg border transition-all duration-300"
  aria-label="Toggle theme"
  aria-pressed="false"
>
  <img
    src="/icons/moon.svg"
    alt=""
    width="18"
    height="18"
    class="theme-icon-moon transition-transform duration-300"
  />
  <img
    src="/icons/sun.svg"
    alt=""
    width="18"
    height="18"
    class="theme-icon-sun hidden transition-transform duration-300"
  />
</button>

<script is:inline>
  const button = document.querySelector('#theme-switcher')
  if (!button) {
    throw new Error('Theme switcher button not found')
  }

  const moonIcon = button.querySelector('.theme-icon-moon')
  const sunIcon = button.querySelector('.theme-icon-sun')

  if (!moonIcon || !sunIcon) {
    throw new Error('Theme switcher icons not found')
  }

  const syncButtonTheme = () => {
    const isDark = document.documentElement.classList.contains('dark')
    button.setAttribute('aria-pressed', String(isDark))
    button.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode')
    moonIcon.classList.toggle('hidden', isDark)
    sunIcon.classList.toggle('hidden', !isDark)
  }

  syncButtonTheme()

  button.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark')
    localStorage.setItem('theme', isDark ? 'dark' : 'light')
    syncButtonTheme()
  })
</script>
