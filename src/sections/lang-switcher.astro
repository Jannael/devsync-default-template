---
import { defaultLang, languages } from '@/devsync/devsync'

interface Props {
  currentLang?: string
  class?: string
}

const { currentLang = defaultLang, class: className } = Astro.props
---

{
  languages.length > 1 && (
    <nav
      aria-label="Language selector"
      class={`${className ?? ''} flex items-center gap-1 rounded-lg border border-border bg-main p-1`}
    >
      {languages.map((lang) => {
        const isActive = lang === currentLang
        return (
          <a
            href={`/${lang}/`}
            aria-current={isActive ? 'page' : undefined}
            class={`rounded-md px-3 py-1.5 text-xs font-semibold uppercase tracking-wider transition-all duration-300 ${
              isActive 
                ? 'bg-accent text-white' 
                : 'text-text-secondary hover:text-accent'
            }`}
          >
            {lang}
          </a>
        )
      })}
    </nav>
  )
}
