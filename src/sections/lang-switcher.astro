---
import { defaultLang, languages } from '@/devsync/devsync'

interface Props {
  currentLang?: string
  class?: string
}

const { currentLang = defaultLang, class: className } = Astro.props
---

{
  languages.length > 1 && (
    <nav
      aria-label="Language selector"
      class={`${className ?? ''} ${className ?? ''}`}
    >
      <div class="relative rounded-full border border-text/15 bg-main/50 p-1.5 shadow-lg shadow-main/10 backdrop-blur-sm">
        {languages.map((lang) => {
          const isActive = lang === currentLang
          return (
            <a
              href={`/${lang}/`}
              aria-current={isActive ? 'page' : undefined}
              class={`relative z-10 inline-block rounded-full px-5 py-2 text-sm font-semibold uppercase tracking-wider transition-all duration-300 ${
                isActive 
                  ? 'bg-accent text-main shadow-lg shadow-accent/30' 
                  : 'text-text/70 hover:text-accent'
              }`}
            >
              {lang}
            </a>
          )
        })}
      </div>
    </nav>
  )
}