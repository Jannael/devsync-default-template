---
import devsync from '@/devsync'
import { defaultLang } from '@/devsync'
import { translations, type availableLangsType } from '@/const/fields-translations'
import ProjectCard from '@/components/project-card.astro'

const lang = (Astro.params.lang || defaultLang).toLowerCase() as availableLangsType
const profile = devsync[lang] ?? devsync[defaultLang]
const projects = profile.projects ?? []
const translation = translations[lang]
---

{
  projects.length > 0 && (
    <section class="relative m-auto flex h-fit w-full max-w-5xl flex-col items-center justify-center lg:pb-20">
      <h2 class="mb-20 text-xl lg:text-5xl">{translation['Projects']}</h2>
      <ul class="relative flex w-full flex-wrap gap-10 px-10 lg:px-0">
        {projects.map(({ name, img, web, links, description, list, skills }) => (
          <ProjectCard {name} {img} {web} {links} {description} {list} {skills} />
        ))}
      </ul>
    </section>
  )
}
