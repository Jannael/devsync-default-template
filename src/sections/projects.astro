---
import devsync from '@/devsync/devsync'
import { defaultLang } from '@/devsync/devsync'
import { translations, type availableLangsType } from '@/devsync/fields-translations'
import ProjectCard from '@/components/project-card.astro'

const lang = (Astro.params.lang || defaultLang).toLowerCase() as availableLangsType
const profile = devsync[lang] ?? devsync[defaultLang]
const projects = profile.projects ?? []
const translation = translations[lang]
---

{
  projects.length > 0 && (
    <section class="relative m-auto flex h-fit w-full max-w-6xl flex-col items-center justify-center px-6 lg:pb-24">
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-3xl font-bold tracking-tight lg:text-5xl">{translation['Projects']}</h2>
        <div class="section-divider mx-auto w-24" />
      </div>
      <ul class="relative flex w-full flex-wrap justify-center gap-8 lg:gap-10">
        {projects.map(({ name, img, web, links, description, list, skills }) => (
          <ProjectCard {name} {img} {web} {links} {description} {list} {skills} />
        ))}
      </ul>
    </section>
  )
}