---
import devsync from '@core'
import { defaultLang, getLangData } from '@core'
import { translations, type availableLangsType } from '@core'
import ProjectCard from '@/components/project-card.astro'

const lang = (Astro.params.lang || defaultLang).toLowerCase() as availableLangsType
const profile = getLangData(devsync, lang)
const projects = profile.projects ?? []
const translation = translations[lang]
---

{
	Array.isArray(projects) && projects.length > 0 && (
		<section id="projects" class="relative m-auto w-full max-w-4xl px-6 py-16">
			<div class="mb-12">
				<h2 class="bg-accent-light mb-2 inline-block rounded px-3 py-1 text-2xl font-bold lg:text-3xl">{translation['Projects']}</h2>
			</div>

			<ul class="grid gap-6 md:grid-cols-2">
				{projects.map(({ name, img, web, links, description, list, skills }) => (
					<ProjectCard {name} {img} {web} {links} {description} {list} {skills} />
				))}
			</ul>
		</section>
	)
}
