---
import devsync from '@/devsync/devsync'
import { defaultLang } from '@/devsync/devsync'
import '@/styles/global.css'
import Navbar from '@/components/navbar.astro'
import Footer from '@/sections/footer.astro'
import '@fontsource-variable/roboto/wght.css'
import jostLatinWoff2 from '@fontsource-variable/jost/files/jost-latin-wght-normal.woff2?url'
import { ogLocale } from '@/devsync/fields-translations'

interface Props {
  title?: string
  description?: string
}

const lang = (Astro.params.lang || defaultLang).toLowerCase()
const profile = devsync[lang] ?? devsync[defaultLang]

// Build dynamic SEO from DEVSYNC.json data
const seoTitle = profile?.jobTitle ? `${devsync.name} | ${profile.jobTitle}` : devsync.name

const seoDescription =
  profile?.description?.split('. ').slice(0, 2).join('. ') || profile?.description

// Extract social links for structured data
const socialLinks = [
  `https://github.com/${devsync.githubUserName}`,
  ...(devsync.socialMedia?.map((s) => s.url) || []),
].filter(Boolean)

if (!Astro.site && !devsync.site) {
  console.warn(`
		[devsync] No site URL configured!
    Add 'site' to astro.config.mjs to fix canonical and OG tags.
  `)
}

const site = Astro.site ?? new URL(devsync.site ?? 'https://devsync.work').toString()
const canonicalUrl = new URL(Astro.url.pathname, site).toString()
const ogImageUrl = new URL('/logo-og.png', site).toString()
const ogImageAlt = `${devsync.name} - ${profile?.jobTitle || 'Professional Profile'}`
const homeUrl = new URL('/', site).toString()
const websiteId = `${homeUrl}#website`
const personId = `${homeUrl}#person`

const { title = seoTitle, description = seoDescription } = Astro.props

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': personId,
      name: devsync.name,
      jobTitle: profile?.jobTitle,
      description: profile?.description,
      url: homeUrl,
      image: devsync.img,
      sameAs: socialLinks,
    },
    {
      '@type': 'WebSite',
      '@id': websiteId,
      url: homeUrl,
      name: seoTitle,
      description,
      inLanguage: lang,
      publisher: {
        '@id': personId,
      },
    },
  ],
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon-32x32.svg" sizes="32x32" type="image/svg+xml" />
    <link rel="icon" href="/favicon-16x16.svg" sizes="16x16" type="image/svg+xml" />
    <link
      rel="icon"
      href="/logo-192-black.webp"
      sizes="192x192"
      type="image/webp"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      href="/logo-192-white.webp"
      sizes="192x192"
      type="image/webp"
      media="(prefers-color-scheme: dark)"
    />
    <link
      rel="apple-touch-icon"
      href="/apple-touch-icon-black.webp"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="apple-touch-icon"
      href="/apple-touch-icon-white.webp"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="apple-touch-icon" href="/apple-touch-icon-white.webp" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href={jostLatinWoff2} as="font" type="font/woff2" crossorigin />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content={seoTitle} />
    <meta property="og:locale" content={ogLocale(lang)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1254" />
    <meta property="og:image:height" content="1254" />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <script>
      const matchMedia = window.matchMedia('(prefers-color-scheme: dark)')
      const hasStoredTheme = () => localStorage.getItem('theme') !== null
      const getTheme = () =>
        localStorage.getItem('theme') ?? (matchMedia.matches ? 'dark' : 'light')
      const applyTheme = () => {
        document.documentElement.classList.toggle('dark', getTheme() === 'dark')
      }

      applyTheme()

      matchMedia.addEventListener('change', () => {
        if (!hasStoredTheme()) {
          applyTheme()
        }
      })
    </script>
  </head>
  <body class="max-w-9xl bg-main text-text m-auto min-h-screen">
    <Navbar />
    <main class="min-h-[calc(100vh-120px)]">
      <slot />
    </main>
    <Footer />
  </body>

  <style is:global>
    html {
      font-family: 'Jost Variable', sans-serif;
    }
  </style>
</html>
