{
	"name": "@devsync/template",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"build:preview": "node scripts/copy-preview && bunx @jannael/devsync build && node scripts/move-cv-pdfs.js && git reset --hard && git clean -fd",
		"preview": "astro preview",
		"astro": "astro",
		"deploy": "bun run build:preview && wrangler pages deploy",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"fmt": "prettier --write .",
		"fmt:check": "prettier --check .",
		"prepare": "husky"
	},
	"dependencies": {
		"@astrojs/sitemap": "3.7.3",
		"@fontsource-variable/jost": "5.2.8",
		"@fontsource-variable/roboto": "5.2.10",
		"@tailwindcss/vite": "4.3.0",
		"astro": "6.4.4",
		"sharp": "^0.34.5",
		"tailwindcss": "4.3.0",
		"zod": "4.4.3"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"devsync": {
		"pathToCompiledCV": "./dist/[lang]/cv/index.html"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"eslint": "10.4.1",
		"eslint-plugin-astro": "1.7.0",
		"husky": "9.1.7",
		"lint-staged": "17.0.7",
		"prettier": "3.8.4",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"typescript-eslint": "8.61.0",
		"wrangler": "4.98.0"
	}
}
