{
  "name": "@devsync/template",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:preview": "node scripts/copy-preview && bunx @jannael/devsync build && node scripts/move-cv-pdfs.js && git reset --hard && git clean -fd",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "bun run build:preview && wrangler pages deploy"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@fontsource-variable/jost": "5.2.8",
    "@fontsource-variable/roboto": "5.2.10",
    "@tailwindcss/vite": "4.3.0",
    "astro": "6.4.4",
    "sharp": "^0.34.5",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devsync": {
    "pathToCompiledCV": "./dist/[lang]/cv/index.html"
  },
  "devDependencies": {
    "wrangler": "4.98.0"
  }
}
