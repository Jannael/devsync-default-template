{
  "name": "@devsync/template",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "node scripts/copy-preview && bunx @jannael/devsync build && node scripts/move-cv-pdfs.js && git reset --hard && git clean -fd && wrangler pages deploy",
    "lint:fix": "oxlint --fix",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/jost": "5.2.8",
    "@fontsource-variable/roboto": "5.2.10",
    "@tailwindcss/vite": "4.2.4",
    "astro": "6.1.9",
    "sharp": "^0.34.5",
    "tailwindcss": "4.2.4",
    "zod": "3.25.76"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devsync": {
    "pathToCompiledCV": "./dist/[lang]/cv/index.html"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "oxlint": "1.64.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "wrangler": "4.92.0"
  },
  "lint-staged": {
    "*.{astro,js,ts,mjs}": [
      "prettier --write",
      "oxlint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
