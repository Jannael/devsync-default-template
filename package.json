{
  "name": "@devsync/template",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "node scripts/copy-preview && bunx @jannael/devsync build && node scripts/move-cv-pdfs.js && git reset --hard && git clean -fd && wrangler pages deploy"
  },
  "dependencies": {
    "@fontsource-variable/jost": "5.2.8",
    "@fontsource-variable/roboto": "5.2.10",
    "@tailwindcss/vite": "4.2.4",
    "astro": "6.1.9",
    "tailwindcss": "4.2.4",
    "zod": "3.25.76"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devsync": {
    "pathToCompiledCV": "./dist/[lang]/cv/index.html"
  },
  "devDependencies": {
    "oxlint": "1.64.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "wrangler": "4.92.0"
  }
}
